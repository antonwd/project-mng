# rendered by installer/install.sh — do not edit by hand
name: projectmng

networks:
  pm_internal:
    driver: bridge

volumes:
  pg_data:
  redis_data:

services:
  postgres:
    image: postgres:16-alpine
    restart: unless-stopped
    environment:
      POSTGRES_USER: projectmng
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: projectmng
    volumes:
      - pg_data:/var/lib/postgresql/data
    networks: [pm_internal]
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U projectmng -d projectmng"]
      interval: 5s
      timeout: 5s
      retries: 10

  redis:
    image: redis:7-alpine
    restart: unless-stopped
    command: ["redis-server", "--save", "60", "1"]
    volumes:
      - redis_data:/data
    networks: [pm_internal]

  docker-socket-proxy:
    image: tecnativa/docker-socket-proxy:0.3
    restart: unless-stopped
    environment:
      CONTAINERS: 1
      IMAGES: 1
      BUILD: 1
      NETWORKS: 1
      EXEC: 1
      POST: 1
      VOLUMES: 0
      SWARM: 0
      SYSTEM: 0
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks: [pm_internal]

  pm-api:
    image: ghcr.io/${IMAGE_OWNER}/api:${VERSION}
    restart: unless-stopped
    depends_on:
      postgres: { condition: service_healthy }
      redis:    { condition: service_started }
      docker-socket-proxy: { condition: service_started }
    environment:
      NODE_ENV: production
      DATABASE_URL: postgres://projectmng:${POSTGRES_PASSWORD}@postgres:5432/projectmng
      REDIS_URL: redis://redis:6379
      MASTER_KEY_PATH: /run/secrets/master.key
      HELPER_SOCKET_PATH: /run/projectmng/helper.sock
      DOCKER_PROXY_URL: http://docker-socket-proxy:2375
      GITHUB_APP_ID: ${GITHUB_APP_ID}
      GITHUB_APP_PRIVATE_KEY_PATH: /run/secrets/github-app.pem
      GITHUB_WEBHOOK_SECRET: ${GITHUB_WEBHOOK_SECRET}
      PUBLIC_BASE_URL: ${PUBLIC_BASE_URL}
      WEBAUTHN_RP_ID: ${WEBAUTHN_RP_ID}
      WEBAUTHN_RP_NAME: projectMng
      COOKIE_SECRET: ${COOKIE_SECRET}
      INTERNAL_PORT_MIN: "10000"
      INTERNAL_PORT_MAX: "19999"
      NGINX_MANAGED_DIR: /etc/nginx/projectmng-managed
      ACME_EMAIL: ${ACME_EMAIL}
      HTTP_PORT: "3000"
    user: "${PM_UID}:${PM_GID}"
    volumes:
      - /etc/projectmng/master.key:/run/secrets/master.key:ro
      - /etc/projectmng/github-app.pem:/run/secrets/github-app.pem:ro
      - /run/projectmng:/run/projectmng
    ports:
      - "127.0.0.1:3001:3000"
    networks: [pm_internal]
    command: ["node", "dist/index.api.js"]

  pm-worker:
    image: ghcr.io/${IMAGE_OWNER}/api:${VERSION}
    restart: unless-stopped
    depends_on:
      pm-api: { condition: service_started }
    environment:
      NODE_ENV: production
      DATABASE_URL: postgres://projectmng:${POSTGRES_PASSWORD}@postgres:5432/projectmng
      REDIS_URL: redis://redis:6379
      MASTER_KEY_PATH: /run/secrets/master.key
      HELPER_SOCKET_PATH: /run/projectmng/helper.sock
      DOCKER_PROXY_URL: http://docker-socket-proxy:2375
      # docker CLI / nixpacks shell out to dockerd; route them through the
      # same socket-proxy as dockerode so they don't need the raw unix socket.
      DOCKER_HOST: tcp://docker-socket-proxy:2375
      # Force the legacy /build endpoint instead of buildkit. buildkit needs
      # its own gRPC socket which the socket-proxy doesn't expose; the legacy
      # path is just the daemon's HTTP /build, which the proxy permits via
      # BUILD=1. Pinned here so future docker upgrades don't silently flip it.
      DOCKER_BUILDKIT: "0"
      # The projectmng user inside the container has no /etc/passwd entry,
      # so HOME is empty and the docker CLI tries to mkdir /.docker — fails.
      # Point HOME + DOCKER_CONFIG at a writable dir.
      HOME: /tmp
      DOCKER_CONFIG: /tmp/.docker
      GITHUB_APP_ID: ${GITHUB_APP_ID}
      GITHUB_APP_PRIVATE_KEY_PATH: /run/secrets/github-app.pem
      GITHUB_WEBHOOK_SECRET: ${GITHUB_WEBHOOK_SECRET}
      PUBLIC_BASE_URL: ${PUBLIC_BASE_URL}
      WEBAUTHN_RP_ID: ${WEBAUTHN_RP_ID}
      WEBAUTHN_RP_NAME: projectMng
      COOKIE_SECRET: ${COOKIE_SECRET}
      INTERNAL_PORT_MIN: "10000"
      INTERNAL_PORT_MAX: "19999"
      NGINX_MANAGED_DIR: /etc/nginx/projectmng-managed
      ACME_EMAIL: ${ACME_EMAIL}
      HTTP_PORT: "3000"
    user: "${PM_UID}:${PM_GID}"
    # nixpacks and `docker build` use the buildkit gRPC client, which only
    # speaks over /var/run/docker.sock — the socket-proxy can't proxy gRPC,
    # only the HTTP daemon API. Mount the raw socket and add the host's
    # docker GID so the unprivileged projectmng user inside the container
    # can use it. pm-api still goes through the proxy for runtime container
    # ops; only build-time tools touch the raw socket.
    group_add:
      - "${DOCKER_GID}"
    volumes:
      - /etc/projectmng/master.key:/run/secrets/master.key:ro
      - /etc/projectmng/github-app.pem:/run/secrets/github-app.pem:ro
      - /run/projectmng:/run/projectmng
      - /var/run/docker.sock:/var/run/docker.sock
    networks: [pm_internal]
    command: ["node", "dist/index.worker.js"]

  pm-web:
    image: ghcr.io/${IMAGE_OWNER}/web:${VERSION}
    restart: unless-stopped
    depends_on:
      pm-api: { condition: service_started }
    environment:
      NODE_ENV: production
      PM_API_URL: http://pm-api:3000
      NEXT_PUBLIC_WEBAUTHN_RP_ID: ${WEBAUTHN_RP_ID}
    ports:
      - "127.0.0.1:3002:3000"
    networks: [pm_internal]
